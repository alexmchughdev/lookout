# Keep the build context tiny + reproducible.

# Build artifacts
lookout
dist/
reports/
*.html

# Local config / runtime state
.env
.env.*
.lookout/
*.yaml
*.yml
!examples/*.yaml
!/go.mod
!/go.sum

# VCS + CI + docs
.git/
.github/
.claude/
docs/
*.md

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
Thumbs.db

# Tests / scripts that aren't needed inside the image
scripts/

# The Dockerfile itself doesn't need to be in its own context
Dockerfile
.dockerignore
